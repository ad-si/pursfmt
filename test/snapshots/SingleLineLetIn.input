-- @format --single-line-let-in
module SingleLineLetIn where

-- Simple let expression that fits on one line
simple = let x = 42 in x + 1

-- Let in lambda argument (motivating case)
sortOn' f = map snd <<< sortBy (comparing fst) <<< map (\x -> let y = f x in Tuple y x)

-- Multiple bindings (should NOT be single-lined)
multiple =
  let
    a = 1
    b = 2
  in a + b

-- Let in case branch
caseLetSingle = case x of
  Just a ->
    let helper = a + 1
    in helper * 2
  Nothing -> 0

-- Nested single-binding lets
nested =
  let outer = 10
  in let inner = 20
     in outer + inner

-- Let with lambda body
letWithLambda =
  let f = \x -> x + 1
  in f 42

-- Let with pattern binding
patternLet =
  let Tuple a b = tuple
  in a + b

-- Let in lambda body
lambdaLet = \x ->
  let y = x * 2
  in y + 1

-- Let with complex body (case expression)
complexBody =
  let x = 1
  in case x of
    1 -> "one"
    _ -> "other"

-- Let with where clause
letWithWhere =
  let x = helper
  in x + 1
  where
  helper = 42

-- Let with do block in binding (single binding but multiline)
letWithDo =
  let
    action = do
      x <- getSomething
      y <- getSomethingElse
      pure (x + y)
  in runAction action
